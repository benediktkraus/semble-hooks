{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/scripts/code-bootstrap.mjs",
            "name": "semble-bootstrap",
            "description": "Warm up Semble code index for current project",
            "timeout": 120000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/scripts/code-recall.mjs",
            "name": "semble-recall",
            "description": "Inject relevant code chunks from current project",
            "timeout": 8000
          }
        ]
      }
    ]
  }
}
